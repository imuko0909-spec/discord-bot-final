def init_db():
    db.execute(
        """
        CREATE TABLE IF NOT EXISTS user_lists (
            owner_id INTEGER NOT NULL,
            list_type TEXT NOT NULL,
            target_id INTEGER NOT NULL,
            PRIMARY KEY (owner_id, list_type, target_id)
        )
        """
    )
    db.commit()


def is_in_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "SELECT 1 FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id),
    )
    return cur.fetchone() is not None


def add_to_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "INSERT OR IGNORE INTO user_lists VALUES (?, ?, ?)",
        (owner_id, list_type, target_id),
    )
    db.commit()
    return cur.rowcount > 0


def remove_from_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "DELETE FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id),
    )
    db.commit()
    return cur.rowcount > 0


def get_list(owner_id: int, list_type: str) -> list[int]:
    cur = db.execute(
        "SELECT target_id FROM user_lists WHERE owner_id=? AND list_type=?",
        (owner_id, list_type),
    )
    return [row[0] for row in cur.fetchall()]


init_db()


class MyBot(commands.Bot):
    def __init__(self):
        super().__init__(command_prefix="!", intents=intents)
        self.synced = False

    async def setup_hook(self):
        self.add_view(CreateVCView())

    async def on_ready(self):
        if not self.synced:
            try:
                for guild in self.guilds:
                    self.tree.copy_global_to(guild=guild)
                    synced = await self.tree.sync(guild=guild)
                    print(f"✅ {guild.name} に {len(synced)} 件同期しました。")
                self.synced = True
            except Exception as e:
                print(f"❌ 同期エラー: {e}")

        print(f"✅ {self.user} でログイン完了。")


bot = MyBot()


@bot.tree.error
async def on_app_command_error(interaction: discord.Interaction, error: app_commands.AppCommandError):
    print(f"[コマンドエラー] {type(error).__name__}: {error}")
    try:
        msg = "エラーが発生しました。"
        if interaction.response.is_done():
            await interaction.followup.send(msg, ephemeral=True)
        else:
            await interaction.response.send_message(msg, ephemeral=True)
    except discord.HTTPException:
        pass


