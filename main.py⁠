async def get_or_create_private_room_category(guild: discord.Guild):
    category_id = get_config_channel_id(guild.id, "private_room_category_id", 0)
    category = guild.get_channel(category_id) if category_id else None

    if isinstance(category, discord.CategoryChannel):
        return category

    category = discord.utils.get(guild.categories, name="専用ルーム")
    if isinstance(category, discord.CategoryChannel):
        set_config(guild.id, "private_room_category_id", str(category.id))
        return category

    category = await guild.create_category(
        "専用ルーム",
        reason="専用ルーム券用カテゴリー",
    )
    set_config(guild.id, "private_room_category_id", str(category.id))
    return category


async def create_private_room_from_ticket(
    interaction: discord.Interaction,
):
    guild = interaction.guild
    owner = interaction.user

    existing = get_private_room_record(guild.id, owner.id)
    if existing:
        voice = guild.get_channel(existing[0])
        text = guild.get_channel(existing[1])
        if voice or text:
            return None, "すでに専用ルームを持っています。"
        delete_private_room_record(guild.id, owner.id)

    category = await get_or_create_private_room_category(guild)

    overwrites = {
        guild.default_role: discord.PermissionOverwrite(
            view_channel=False,
            connect=False,
        ),
        guild.me: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            send_messages=True,
            read_message_history=True,
            manage_channels=True,
            move_members=True,
        ),
        owner: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            send_messages=True,
            read_message_history=True,
        ),
    }

    voice = await guild.create_voice_channel(
        name=f"🔐｜{owner.display_name}専用",
        category=category,
        overwrites=overwrites,
        reason="専用ルーム券使用",
    )

    text = await guild.create_text_channel(
        name=f"🔐-{owner.display_name}-専用",
        category=category,
        overwrites=overwrites,
        topic=f"{owner.display_name}さんの専用ルーム",
        reason="専用ルーム券使用",
    )

    save_private_room_record(guild.id, owner.id, voice.id, text.id)
    ticket_private_rooms[(guild.id, owner.id)] = {
        "voice_id": voice.id,
        "text_id": text.id,
    }

    embed = discord.Embed(
        title="🔐 専用ルームを作成しました",
        description=(
            f"🎙 {voice.mention}\n"
            f"💬 {text.mention}\n\n"
            "`/専用ルーム招待` でメンバーを招待できます。\n"
            "`/専用ルーム終了` で削除できます。"
        ),
        color=discord.Color.gold(),
    )
    await text.send(owner.mention, embed=embed)

    return (voice, text), None


async def delete_private_room(
    guild: discord.Guild,
    owner_id: int,
):
    data = get_private_room_record(guild.id, owner_id)
    if not data:
        return False

    voice = guild.get_channel(data[0])
    text = guild.get_channel(data[1])

    if isinstance(text, discord.TextChannel):
        try:
            await text.delete(reason="専用ルーム終了")
        except discord.HTTPException:
            pass

    if isinstance(voice, discord.VoiceChannel):
        try:
            await voice.delete(reason="専用ルーム終了")
        except discord.HTTPException:
            pass

    delete_private_room_record(guild.id, owner_id)
    ticket_private_rooms.pop((guild.id, owner_id), None)
    return True


