class RecruitView(discord.ui.View):
    def __init__(self, author_id):
        super().__init__(timeout=None)
        self.author_id = author_id

    @discord.ui.button(label="立候補する", style=discord.ButtonStyle.green)
    async def apply(self, interaction, button):
        if interaction.user.id == self.author_id:
            return await safe_reply(interaction, "自分の募集には立候補できません。")

        author = interaction.guild.get_member(self.author_id)
        if author:
            try:
                await author.send(f"📩 {interaction.user.display_name} さんが立候補しました！")
            except discord.HTTPException:
                pass

        await safe_reply(interaction, "立候補しました！")


class RecruitTargetView(discord.ui.View):
    def __init__(self, author_id):
        super().__init__(timeout=60)
        self.author_id = author_id

    async def send_recruit(self, interaction, target):
        channel = discord.utils.get(interaction.guild.text_channels, name=RECRUIT_CHANNEL_NAME)

        if not channel:
            channel = await interaction.guild.create_text_channel(RECRUIT_CHANNEL_NAME)

        embed = discord.Embed(
            title="📢 募集通知",
