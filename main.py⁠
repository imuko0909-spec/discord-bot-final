def apply_server_preset_values(guild_id: int, preset_key: str):
    preset = SERVER_PRESETS.get(preset_key)
    if not preset:
        return None

    set_config(guild_id, "server_preset", preset_key)
    set_config(guild_id, "server_display_name", preset["display_name"])
    set_config(guild_id, "server_status_name", preset["status_name"])
    set_config(guild_id, "server_status_message", preset["status_message"])
    set_config(guild_id, "server_status_theme", preset["theme"])
    set_config(guild_id, "currency_name", preset["currency_name"])
    set_config(guild_id, "daily_reward", preset["daily_reward"])
    set_config(guild_id, "vc_reward_10min", preset["vc_reward_10min"])
    set_config(guild_id, "vc_reward_min_people", preset.get("vc_reward_min_people", "1"))

    return preset


@bot.tree.command(name="apply_server_preset", description="サーバー用プリセットを適用する")
@app_commands.describe(
    preset="melty / puraudhia / midnight"
)
async def apply_server_preset(interaction: discord.Interaction, preset: str):
    if interaction.guild is None:
        return await safe_reply(interaction, "サーバー内で使ってください。")

    if not admin_config_check(interaction):
        return await safe_reply(interaction, "管理者だけ使用できます。")

    preset_key = preset.lower().strip()

    if preset_key not in SERVER_PRESETS:
        return await safe_reply(
            interaction,
            "使えるプリセットは `melty` / `puraudhia` / `midnight` です。"
        )

    data = apply_server_preset_values(interaction.guild.id, preset_key)

    try:
        await update_status_panel(interaction.guild)
    except Exception:
        pass

    embed = discord.Embed(
        title="✅ サーバープリセットを適用しました",
        color=discord.Color.green(),
    )
    embed.add_field(name="サーバー", value=data["display_name"], inline=False)
    embed.add_field(name="ダッシュボード名", value=data["status_name"], inline=False)
    embed.add_field(name="一言", value=data["status_message"], inline=False)
    embed.add_field(name="テーマ", value=data["theme"], inline=True)
    embed.add_field(name="ポイント名", value=data["currency_name"], inline=True)

    await interaction.response.send_message(embed=embed, ephemeral=True)


@bot.tree.command(name="preset_list", description="使えるサーバープリセットを見る")
async def preset_list(interaction: discord.Interaction):
    if interaction.guild is None:
        return await safe_reply(interaction, "サーバー内で使ってください。")

    lines = []
    for key, data in SERVER_PRESETS.items():
        lines.append(
            f"`{key}` **{data['display_name']}**\n"
            f"　テーマ: {data['theme']} / ポイント名: {data['currency_name']}"
        )

    embed = discord.Embed(
        title="📋 サーバープリセット一覧",
        description="\n\n".join(lines),
        color=discord.Color.blurple(),
    )

    await interaction.response.send_message(embed=embed, ephemeral=True)



