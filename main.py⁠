async def create_relay_room(guild: discord.Guild, category, members: list[discord.Member], round_no: int, room_no: int):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=False),
        guild.me: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
        ),
    }

    for member in members:
        overwrites[member] = discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
        )

    return await guild.create_voice_channel(
        name=f"🔁リレー R{round_no}-{room_no}",
        category=category,
        overwrites=overwrites,
    )


async def run_relay_session(guild: discord.Guild, starter_id: int):
    session = relay_sessions.get(guild.id)
    if not session:
        return

    waiting_vc = guild.get_channel(session["waiting_vc_id"])
    if not isinstance(waiting_vc, discord.VoiceChannel):
        relay_sessions.pop(guild.id, None)
        return

    rounds = session["rounds"]
    round_seconds = session["round_seconds"]
    break_seconds = session["break_seconds"]
    category = waiting_vc.category

    try:
        for round_no in range(1, rounds + 1):
            if not session.get("running"):
                break

            participants = [
                m for m in waiting_vc.members
                if not m.bot and m.id != starter_id
            ]

            if len(participants) < 2:
                await send_admin_log(
                    guild,
                    discord.Embed(
                        title="🔁 個室リレー停止",
                        description="参加者が2人未満のため停止しました。",
                        color=discord.Color.red(),
                        timestamp=discord.utils.utcnow(),
                    )
                )
                break

            random.shuffle(participants)
            pairs = []
            for i in range(0, len(participants), 2):
                group = participants[i:i + 2]
                if len(group) == 2:
                    pairs.append(group)

            created_channels = []

            embed = discord.Embed(
                title=f"🔁 個室リレー Round {round_no}/{rounds}",
                description=f"通話時間: {round_seconds}秒",
                color=discord.Color.blurple(),
                timestamp=discord.utils.utcnow(),
            )
            embed.add_field(name="組数", value=f"{len(pairs)}組", inline=True)
            await send_admin_log(guild, embed)

            for idx, pair in enumerate(pairs, start=1):
                channel = await create_relay_room(guild, category, pair, round_no, idx)
                created_channels.append(channel)

                for member in pair:
                    try:
                        await member.move_to(channel)
                    except discord.HTTPException:
                        pass

            await asyncio.sleep(round_seconds)

            for channel in created_channels:
                for member in list(channel.members):
                    try:
                        await member.move_to(waiting_vc)
                    except discord.HTTPException:
                        pass

                try:
                    await channel.delete()
                except discord.HTTPException:
                    pass

            if round_no < rounds and session.get("running"):
                await asyncio.sleep(break_seconds)

        relay_sessions.pop(guild.id, None)

        await send_admin_log(
            guild,
            discord.Embed(
                title="✅ 個室リレー終了",
                description="個室リレーが終了しました。",
                color=discord.Color.green(),
                timestamp=discord.utils.utcnow(),
            )
        )

    except Exception:
        traceback.print_exc()
        relay_sessions.pop(guild.id, None)


