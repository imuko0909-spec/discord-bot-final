def add_ticket(guild_id: int, user_id: int, ticket_key: str, amount: int = 1):
    if amount <= 0:
        return
    db.execute(
        """
        INSERT INTO economy_tickets (guild_id, user_id, ticket_key, amount)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(guild_id, user_id, ticket_key)
        DO UPDATE SET amount = economy_tickets.amount + excluded.amount
        """,
        (guild_id, user_id, ticket_key, amount),
    )
    db.commit()


def remove_ticket(guild_id: int, user_id: int, ticket_key: str, amount: int = 1):
    cur = db.execute(
        """
        SELECT amount FROM economy_tickets
        WHERE guild_id=? AND user_id=? AND ticket_key=?
        """,
        (guild_id, user_id, ticket_key),
    )
    row = cur.fetchone()
    if not row or int(row[0]) < amount:
        return False

    remaining = int(row[0]) - amount
    if remaining <= 0:
        db.execute(
            """
            DELETE FROM economy_tickets
            WHERE guild_id=? AND user_id=? AND ticket_key=?
            """,
            (guild_id, user_id, ticket_key),
        )
    else:
        db.execute(
            """
            UPDATE economy_tickets SET amount=?
            WHERE guild_id=? AND user_id=? AND ticket_key=?
            """,
            (remaining, guild_id, user_id, ticket_key),
        )
    db.commit()
    return True


