def init_db():
    db.execute("""
        CREATE TABLE IF NOT EXISTS user_lists (
            owner_id INTEGER NOT NULL,
            list_type TEXT NOT NULL,
            target_id INTEGER NOT NULL,
            PRIMARY KEY (owner_id, list_type, target_id)
        )
    """)

    db.execute("""
        CREATE TABLE IF NOT EXISTS user_stats (
            guild_id INTEGER NOT NULL,
            user_id INTEGER NOT NULL,
            vc_created INTEGER DEFAULT 0,
            knock_rooms INTEGER DEFAULT 0,
            free_rooms INTEGER DEFAULT 0,
            knocks_sent INTEGER DEFAULT 0,
            knocks_received INTEGER DEFAULT 0,
            knocks_allowed INTEGER DEFAULT 0,
            knocks_denied INTEGER DEFAULT 0,
            recruit_count INTEGER DEFAULT 0,
            extend_count INTEGER DEFAULT 0,
            total_seconds INTEGER DEFAULT 0,
            PRIMARY KEY (guild_id, user_id)
        )
    """)

    db.execute("""
        CREATE TABLE IF NOT EXISTS room_logs (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            guild_id INTEGER NOT NULL,
            owner_id INTEGER NOT NULL,
            room_type TEXT NOT NULL,
            created_at INTEGER NOT NULL,
            ended_at INTEGER,
            duration_seconds INTEGER DEFAULT 0
        )
    """)

    db.commit()


def add_to_list(owner_id, list_type, target_id):
    cur = db.execute(
        "INSERT OR IGNORE INTO user_lists VALUES (?, ?, ?)",
        (owner_id, list_type, target_id)
    )
    db.commit()
    return cur.rowcount > 0


def remove_from_list(owner_id, list_type, target_id):
    cur = db.execute(
        "DELETE FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id)
    )
    db.commit()
    return cur.rowcount > 0


def is_in_list(owner_id, list_type, target_id):
    cur = db.execute(
        "SELECT 1 FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id)
    )
    return cur.fetchone() is not None


def get_list(owner_id, list_type):
    cur = db.execute(
        "SELECT target_id FROM user_lists WHERE owner_id=? AND list_type=?",
        (owner_id, list_type)
    )
    return [row[0] for row in cur.fetchall()]


def add_stat(guild_id, user_id, column, amount=1):
    allowed = {
        "vc_created", "knock_rooms", "free_rooms",
        "knocks_sent", "knocks_received", "knocks_allowed",
        "knocks_denied", "recruit_count", "extend_count",
        "total_seconds"
    }

    if column not in allowed:
        return

    db.execute(
        "INSERT OR IGNORE INTO user_stats (guild_id, user_id) VALUES (?, ?)",
        (guild_id, user_id)
    )
    db.execute(
        f"UPDATE user_stats SET {column} = {column} + ? WHERE guild_id=? AND user_id=?",
        (amount, guild_id, user_id)
    )
    db.commit()


def create_room_log(guild_id, owner_id, room_type):
    now = int(time.time())
    cur = db.execute(
        "INSERT INTO room_logs (guild_id, owner_id, room_type, created_at) VALUES (?, ?, ?, ?)",
        (guild_id, owner_id, room_type, now)
    )
    db.commit()
    return cur.lastrowid


def finish_room_log(log_id, guild_id, owner_id):
    if not log_id:
        return

    cur = db.execute("SELECT created_at, ended_at FROM room_logs WHERE id=?", (log_id,))
    row = cur.fetchone()
    if not row or row[1] is not None:
        return

    now = int(time.time())
    duration = max(0, now - row[0])

    db.execute(
        "UPDATE room_logs SET ended_at=?, duration_seconds=? WHERE id=?",
        (now, duration, log_id)
    )
    db.commit()

    add_stat(guild_id, owner_id, "total_seconds", duration)


def format_seconds(seconds):
    seconds = int(seconds or 0)
    hours = seconds // 3600
    minutes = (seconds % 3600) // 60
    return f"{hours}時間{minutes}分"


