class KnockDecisionView(discord.ui.View):
    def __init__(self, guild_id: int, channel_id: int, requester_id: int):
        super().__init__(timeout=180)
        self.guild_id = guild_id
        self.channel_id = channel_id
        self.requester_id = requester_id

    @discord.ui.button(label="✅ 許可", style=discord.ButtonStyle.success)
    async def allow(self, interaction: discord.Interaction, button: discord.ui.Button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            guild, channel = get_room_guild_and_channel(self.guild_id, self.channel_id)
            if not guild or not channel:
                return await safe_reply(interaction, "サーバーまたは部屋が見つかりません。")

            member = guild.get_member(self.requester_id)
            if not member:
                return await safe_reply(interaction, "対象メンバーが見つかりません。")

            await channel.set_permissions(member, view_channel=True, connect=True, speak=True)
            add_stat(guild.id, room["owner_id"], "knocks_allowed")

            try:
                if member.voice and member.voice.channel:
                    await member.move_to(channel)
            except discord.HTTPException:
                pass

            try:
                await member.send(f"✅ **{guild.name}** の **{channel.name}** への入室が許可されました。")
            except discord.HTTPException:
                pass

            for item in self.children:
                item.disabled = True

            await safe_reply(interaction, f"✅ {member.display_name} さんを許可しました。")

            try:
                await interaction.message.edit(view=self)
            except Exception:
                pass

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "許可処理でエラーが発生しました。")

    @discord.ui.button(label="❌ 拒否", style=discord.ButtonStyle.danger)
    async def deny(self, interaction: discord.Interaction, button: discord.ui.Button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            guild, _channel = get_room_guild_and_channel(self.guild_id, self.channel_id)
            if not guild:
                return await safe_reply(interaction, "サーバーが見つかりません。")

            add_stat(guild.id, room["owner_id"], "knocks_denied")
            member = guild.get_member(self.requester_id)

            if member:
                try:
                    await member.send(f"❌ **{guild.name}** のノックは拒否されました。")
                except discord.HTTPException:
                    pass

            for item in self.children:
                item.disabled = True

            await safe_reply(interaction, f"❌ {member.display_name if member else '相手'} さんを拒否しました。")

            try:
                await interaction.message.edit(view=self)
            except Exception:
                pass

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "拒否処理でエラーが発生しました。")


async def send_knock_dm(interaction: discord.Interaction, channel_id: int):
    room = rooms.get(channel_id)
    if not room:
        return await safe_reply(interaction, "この部屋はもう存在しません。")

    guild = interaction.guild
    owner = guild.get_member(room["owner_id"])
    channel = guild.get_channel(channel_id)

    if not owner or not channel:
        return await safe_reply(interaction, "部屋主または部屋が見つかりません。")

    if interaction.user.id == owner.id:
        return await safe_reply(interaction, "自分の部屋にはノック不要です。")

    if is_in_list(owner.id, "blacklist", interaction.user.id):
        return await safe_reply(interaction, "この部屋にはノックできません。")

    add_stat(guild.id, interaction.user.id, "knocks_sent")
    add_stat(guild.id, owner.id, "knocks_received")

    if is_in_list(owner.id, "favorites", interaction.user.id):
        await channel.set_permissions(interaction.user, view_channel=True, connect=True, speak=True)
        add_stat(guild.id, owner.id, "knocks_allowed")
        return await safe_reply(interaction, "❤️ お気に入り登録されているため、入室許可されました。")

    try:
        await owner.send(
            f"🚪 **ノック通知**\n\n"
            f"**{interaction.user.display_name}** さんがあなたのノック部屋に入りたいようです。\n\n"
            f"サーバー: **{guild.name}**\n"
            f"部屋: **{channel.name}**\n\n"
            f"下のボタンで許可・拒否できます。",
            view=KnockDecisionView(guild.id, channel_id, interaction.user.id),
        )
        await safe_reply(interaction, "部屋主にDMでノックを送りました！")
    except discord.Forbidden:
        await safe_reply(interaction, "部屋主にDMが送れませんでした。部屋主のDM設定を確認してください。")
    except discord.HTTPException:
        traceback.print_exc()
        await safe_reply(interaction, "DM送信に失敗しました。")


class KnockRoomSelect(discord.ui.Select):
    def __init__(self, guild: discord.Guild, requester_id: int):
        options = []

        for channel_id, room in rooms.items():
            if room.get("type") != "knock":
                continue

            channel = guild.get_channel(channel_id)
            owner = guild.get_member(room.get("owner_id"))

            if not channel or not owner:
                continue

            if owner.id == requester_id:
                continue

            options.append(
                discord.SelectOption(
                    label=channel.name[:100],
                    description=f"部屋主: {owner.display_name}"[:100],
                    value=str(channel_id),
                )
            )

        if not options:
            options = [discord.SelectOption(label="ノックできる部屋がありません", value="none")]

        super().__init__(
            placeholder="ノックする部屋を選んでください",
            min_values=1,
            max_values=1,
            options=options[:25],
        )

    async def callback(self, interaction: discord.Interaction):
        if self.values[0] == "none":
            return await safe_reply(interaction, "ノックできる部屋がありません。")

        await send_knock_dm(interaction, int(self.values[0]))


class KnockRoomSelectView(discord.ui.View):
