@bot.event
async def on_voice_state_update(member, before, after):
    if member.bot:
        return

    if after.channel and after.channel.id == RECEPTION_CHANNEL_ID:
        try:
            channel = await create_free_room(after.channel.guild, member, after.channel.category)
            await member.move_to(channel)
        except Exception:
            traceback.print_exc()

    if before.channel and before.channel.id in rooms:
        if len(before.channel.members) == 0:
            await delete_room(before.channel.id, before.channel.guild)


