def add_to_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "INSERT OR IGNORE INTO user_lists VALUES (?, ?, ?)",
        (owner_id, list_type, target_id),
    )
    db.commit()
    return cur.rowcount > 0


def remove_from_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "DELETE FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id),
    )
    db.commit()
    return cur.rowcount > 0


def is_in_list(owner_id: int, list_type: str, target_id: int) -> bool:
    cur = db.execute(
        "SELECT 1 FROM user_lists WHERE owner_id=? AND list_type=? AND target_id=?",
        (owner_id, list_type, target_id),
    )
    return cur.fetchone() is not None


def get_list(owner_id: int, list_type: str) -> list[int]:
    cur = db.execute(
        "SELECT target_id FROM user_lists WHERE owner_id=? AND list_type=?",
        (owner_id, list_type),
    )
    return [row[0] for row in cur.fetchall()]


def add_stat(guild_id: int, user_id: int, column: str, amount: int = 1):
    allowed = {
        "vc_created",
        "knock_rooms",
        "free_rooms",
        "knocks_sent",
        "knocks_received",
        "knocks_allowed",
        "knocks_denied",
        "recruit_count",
        "total_seconds",
    }

    if column not in allowed:
        return

    db.execute(
        "INSERT OR IGNORE INTO user_stats (guild_id, user_id) VALUES (?, ?)",
        (guild_id, user_id),
    )
    db.execute(
        f"UPDATE user_stats SET {column} = {column} + ? WHERE guild_id=? AND user_id=?",
        (amount, guild_id, user_id),
    )
    db.commit()


def create_room_log(guild_id: int, owner_id: int, room_type: str) -> int:
    now = int(time.time())
    cur = db.execute(
        "INSERT INTO room_logs (guild_id, owner_id, room_type, created_at) VALUES (?, ?, ?, ?)",
        (guild_id, owner_id, room_type, now),
    )
    db.commit()
    return cur.lastrowid


def finish_room_log(log_id: int | None, guild_id: int, owner_id: int):
    if not log_id:
        return

    cur = db.execute("SELECT created_at, ended_at FROM room_logs WHERE id=?", (log_id,))
    row = cur.fetchone()

    if not row or row[1] is not None:
        return

    now = int(time.time())
    duration = max(0, now - int(row[0]))

    db.execute(
        "UPDATE room_logs SET ended_at=?, duration_seconds=? WHERE id=?",
        (now, duration, log_id),
    )
    db.commit()

    add_stat(guild_id, owner_id, "total_seconds", duration)


def record_activity(guild_id: int, user_id: int, action: str = "activity"):
    if not guild_id or not user_id:
        return

    now = int(time.time())

    db.execute(
        """
        INSERT INTO user_activity (guild_id, user_id, last_seen, action)
        VALUES (?, ?, ?, ?)
        ON CONFLICT(guild_id, user_id)
        DO UPDATE SET last_seen=excluded.last_seen, action=excluded.action
        """,
        (guild_id, user_id, now, action),
    )
    db.commit()


def format_seconds(seconds: int | None) -> str:
    seconds = int(seconds or 0)
    hours = seconds // 3600
    minutes = (seconds % 3600) // 60
    return f"{hours}時間{minutes}分"


def format_last_seen(timestamp_value: int | None) -> str:
    if not timestamp_value:
        return "記録なし"

    diff = max(0, int(time.time()) - int(timestamp_value))

    if diff < 60:
        return "たった今"
    if diff < 3600:
        return f"{diff // 60}分前"
    if diff < 86400:
        return f"{diff // 3600}時間前"

    return f"{diff // 86400}日前"




