    )


@bot.tree.context_menu(name="マイリスト管理")
async def mylist_menu(interaction: discord.Interaction, member: discord.Member):
    if interaction.user.id != MY_USER_ID:
        return await interaction.response.send_message(
            "あなたはこの機能を使えません。", ephemeral=True
        )

    in_fav = member.id in user_lists["favorites"]
    in_bl = member.id in user_lists["blacklist"]
    status = []
    if in_fav:
        status.append("⭐ お気に入り登録済み")
    if in_bl:
        status.append("🚫 ブラックリスト登録済み")
    status_text = "　".join(status) if status else "未登録"

    await interaction.response.send_message(
        f"**{member.display_name}** さんの管理操作を選択してください：\n現在のステータス: {status_text}",
        view=ActionView(member),
        ephemeral=True
    )


class ExtendButton(discord.ui.View):
    def __init__(self, channel: discord.VoiceChannel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.channel.id in rooms:
            rooms[self.channel.id] += 600
            await interaction.response.send_message(
                f"10分延長しました！（残り {rooms[self.channel.id] // 60}分）", ephemeral=True
            )
        else:
            await interaction.response.send_message(
                "この部屋はすでに存在しません。", ephemeral=True
            )


async def manage_room_timer(channel: discord.VoiceChannel):
    """個室のタイマー管理ループ"""
    while rooms.get(channel.id, 0) > 0:
        await asyncio.sleep(60)
        if channel.id not in rooms:
            return
        rooms[channel.id] -= 60

        if rooms[channel.id] > 0:
            try:
                await channel.send(f"残り時間: {rooms[channel.id] // 60}分")
            except discord.HTTPException:
                pass
        else:
            try:
                await channel.send("時間終了です。部屋を削除します。")
                await channel.delete()
            except discord.HTTPException:
                pass
            rooms.pop(channel.id, None)
            break


async def create_private_room(guild: discord.Guild, member: discord.Member,
                              category: discord.CategoryChannel = None) -> discord.VoiceChannel:
    """個室VCを作成し、タイマーと延長ボタンを設定する"""
    new_channel = await guild.create_voice_channel(
        name=f"{member.display_name}の個室",
        category=category
    )
    rooms[new_channel.id] = 600
    await new_channel.send(
        "個室へようこそ！10分後に削除されます。", view=ExtendButton(new_channel)
    )
    bot.loop.create_task(manage_room_timer(new_channel))
    return new_channel


class CreateVCView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)

    @discord.ui.button(
        label="🎤 VC作成", style=discord.ButtonStyle.success, custom_id="create_vc_button"
    )
    async def create_vc(self, interaction: discord.Interaction, button: discord.ui.Button):
        member = interaction.user
        category = interaction.channel.category if interaction.channel else None
        new_channel = await create_private_room(interaction.guild, member, category)

        if member.voice and member.voice.channel:
            try:
                await member.move_to(new_channel)
                await interaction.response.send_message(
                    f"{new_channel.mention} を作成し、移動しました！", ephemeral=True
                )
                return
            except discord.HTTPException:
                pass
        await interaction.response.send_message(
            f"{new_channel.mention} を作成しました！参加してください。", ephemeral=True
        )


