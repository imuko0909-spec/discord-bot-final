@bot.event
async def on_voice_state_update(member, before, after):
    if (
        RECEPTION_CHANNEL_ID
        and after.channel
        and after.channel.id == RECEPTION_CHANNEL_ID
    ):
        try:
            new_channel = await create_private_room(
                after.channel.guild, member, after.channel.category
            )
            await member.move_to(new_channel)
        except discord.Forbidden:
            print(
                "権限不足: 個室を作成/移動できませんでした。"
                "Botに『チャンネルの管理』『ロールの管理』権限を付与し、ロール順位を上げてください。"
            )

    if before.channel and before.channel.id in rooms:
        if len(before.channel.members) == 0:
            try:
                await before.channel.delete()
            except discord.HTTPException:
                pass
            rooms.pop(before.channel.id, None)


