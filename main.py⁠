    def __init__(self, author_id):
        super().__init__(timeout=60)
        self.author_id = author_id

    async def send_recruit(self, interaction, target):
        channel = discord.utils.get(interaction.guild.text_channels, name=RECRUIT_CHANNEL_NAME)

        if not channel:
            channel = await interaction.guild.create_text_channel(RECRUIT_CHANNEL_NAME)

        embed = discord.Embed(
            title="📢 募集通知",
            description=f"{target}の方、立候補をお待ちしています！",
            color=discord.Color.green()
        )
        embed.set_footer(text=f"募集主: {interaction.user.display_name}")

        await channel.send(embed=embed, view=RecruitView(self.author_id))
        await interaction.response.send_message("募集を送信しました。", ephemeral=True)

    @discord.ui.button(label="男性宛", style=discord.ButtonStyle.primary)
    async def men(self, interaction, button):
        await self.send_recruit(interaction, "男性")

    @discord.ui.button(label="女性宛", style=discord.ButtonStyle.primary)
    async def women(self, interaction, button):
        await self.send_recruit(interaction, "女性")

    @discord.ui.button(label="両方宛", style=discord.ButtonStyle.secondary)
    async def both(self, interaction, button):
        await self.send_recruit(interaction, "男性・女性")


