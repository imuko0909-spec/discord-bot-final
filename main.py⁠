@bot.tree.command(name="ranking", description="VC利用ランキングを見る")
async def ranking(interaction: discord.Interaction):
    if interaction.guild is None:
        return await safe_reply(interaction, "サーバー内で使ってください。")

    cur = db.execute(
        """
        SELECT user_id, vc_created, total_seconds
        FROM user_stats
        WHERE guild_id=?
        ORDER BY vc_created DESC, total_seconds DESC
        LIMIT 10
        """,
        (interaction.guild.id,)
    )

    rows = cur.fetchall()

    if not rows:
        return await safe_reply(interaction, "まだランキングデータがありません。")

    lines = []
    medals = ["🥇", "🥈", "🥉"]

    for i, row in enumerate(rows):
        user_id, vc_created, total_seconds = row
        member = interaction.guild.get_member(user_id)
        name = member.display_name if member else f"退出済み ID:{user_id}"
        mark = medals[i] if i < 3 else f"{i+1}位"
        lines.append(
            f"{mark} **{name}**\n"
            f"　🎤 作成 {vc_created}回 / ⏱ {format_seconds(total_seconds)}"
        )

    embed = discord.Embed(
        title="🏆 VC利用ランキング",
        description="\n\n".join(lines),
        color=discord.Color.gold()
    )

    await interaction.response.send_message(embed=embed)


