            participants = [m for m in waiting_vc.members if not m.bot and m.id != starter_id]

            if len(participants) < 2:
                await send_admin_log(
                    guild,
                    discord.Embed(
                        title="🕊 匿名個室リレー停止",
                        description="参加者が2人未満のため停止しました。",
                        color=discord.Color.red(),
                        timestamp=discord.utils.utcnow(),
                    )
                )
                break

            random.shuffle(participants)
            pairs = [participants[i:i+2] for i in range(0, len(participants), 2) if len(participants[i:i+2]) == 2]
            created_channels = []

            await send_admin_log(
                guild,
                discord.Embed(
                    title=f"🕊 匿名個室リレー Round {round_no}/{rounds}",
                    description=f"通話時間: {round_seconds}秒\n組数: {len(pairs)}組\n※VC内ではDiscord仕様上、参加者名は見えます。",
                    color=discord.Color.purple(),
                    timestamp=discord.utils.utcnow(),
                )
            )

            for idx, pair in enumerate(pairs, start=1):
                overwrites = {
                    guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=False),
                    guild.me: discord.PermissionOverwrite(view_channel=True, connect=True, speak=True, manage_channels=True, move_members=True),
                }
                for member in pair:
                    overwrites[member] = discord.PermissionOverwrite(view_channel=True, connect=True, speak=True)

                channel = await guild.create_voice_channel(
                    name=f"🕊匿名リレー R{round_no}-{idx}",
                    category=category,
                    overwrites=overwrites,
                )
                created_channels.append(channel)

                for member in pair:
                    try:
                        await member.move_to(channel)
                    except discord.HTTPException:
                        pass

            await asyncio.sleep(round_seconds)

            for channel in created_channels:
                for member in list(channel.members):
                    try:
                        await member.move_to(waiting_vc)
                    except discord.HTTPException:
                        pass

                try:
                    await channel.delete()
                except discord.HTTPException:
                    pass

            if round_no < rounds and session.get("running"):
                await asyncio.sleep(break_seconds)

        relay_sessions.pop(guild.id, None)

        await send_admin_log(
            guild,
            discord.Embed(
                title="✅ 匿名個室リレー終了",
                description="匿名個室リレーが終了しました。",
                color=discord.Color.green(),
                timestamp=discord.utils.utcnow(),
            )
        )

    except Exception:
        traceback.print_exc()
        relay_sessions.pop(guild.id, None)


