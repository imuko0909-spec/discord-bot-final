def cancel_empty_delete(channel_id: int):
    task = empty_delete_tasks.pop(channel_id, None)
    if task and not task.done():
        task.cancel()


async def delayed_empty_delete(channel_id: int, guild: discord.Guild, delay_seconds: int = EMPTY_DELETE_SECONDS):
    try:
        await asyncio.sleep(delay_seconds)

        channel = guild.get_channel(channel_id)
        if not channel:
            rooms.pop(channel_id, None)
            empty_delete_tasks.pop(channel_id, None)
            await update_status_panel(guild)
            return

        if channel_id in rooms and len(channel.members) == 0:
            await delete_room(channel_id, guild, reason=f"空室が{delay_seconds}秒続いたため自動削除")
    except asyncio.CancelledError:
        pass
    except Exception:
        traceback.print_exc()
    finally:
        empty_delete_tasks.pop(channel_id, None)


def schedule_empty_delete(channel_id: int, guild: discord.Guild):
    if channel_id not in rooms:
        return

    channel = guild.get_channel(channel_id)
    if not channel or len(channel.members) > 0:
        return

    if channel_id in empty_delete_tasks:
        return

    empty_delete_tasks[channel_id] = bot.loop.create_task(
        delayed_empty_delete(channel_id, guild, EMPTY_DELETE_SECONDS)
    )


async def delete_room(channel_id: int, guild: discord.Guild, reason: str = "不明"):
    cancel_empty_delete(channel_id)

    room = rooms.get(channel_id)
    channel_for_log = guild.get_channel(channel_id)
    channel_name_for_log = channel_for_log.name if channel_for_log else None

    if room:
        await log_room_deleted(guild, room, channel_name_for_log, reason)

        text_channel_id = room.get("knock_text_channel_id")
        message_ids = room.get("message_ids", [])
        text_ch = guild.get_channel(text_channel_id) if text_channel_id else None

        if text_ch:
            for msg_id in list(message_ids):
                try:
                    msg = await text_ch.fetch_message(msg_id)
                    await msg.delete()
                except discord.NotFound:
                    pass
                except discord.HTTPException:
                    pass
                except Exception:
                    traceback.print_exc()

        finish_room_log(room.get("log_id"), guild.id, room.get("owner_id"))

    channel = guild.get_channel(channel_id)
    if channel:
        try:
            await channel.delete()
        except discord.NotFound:
            pass
        except discord.HTTPException:
            pass
        except Exception:
            traceback.print_exc()

    rooms.pop(channel_id, None)


