class KnockDecisionView(discord.ui.View):
    def __init__(self, channel_id, requester_id):
        super().__init__(timeout=180)
        self.channel_id = channel_id
        self.requester_id = requester_id

    @discord.ui.button(label="✅ 許可", style=discord.ButtonStyle.success)
    async def allow(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            channel = interaction.guild.get_channel(self.channel_id)
            member = interaction.guild.get_member(self.requester_id)

            if not channel or not member:
                return await safe_reply(interaction, "対象が見つかりません。")

            await channel.set_permissions(member, view_channel=True, connect=True, speak=True)
            add_stat(interaction.guild.id, room["owner_id"], "knocks_allowed")

            try:
                if member.voice and member.voice.channel:
                    await member.move_to(channel)
            except discord.HTTPException:
                pass

            await safe_reply(interaction, f"✅ {member.display_name} さんを許可しました。")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "許可処理でエラーが発生しました。")

    @discord.ui.button(label="❌ 拒否", style=discord.ButtonStyle.danger)
    async def deny(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            add_stat(interaction.guild.id, room["owner_id"], "knocks_denied")
            member = interaction.guild.get_member(self.requester_id)

            await safe_reply(interaction, f"❌ {member.display_name if member else '相手'} さんを拒否しました。")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "拒否処理でエラーが発生しました。")


class KnockButtonView(discord.ui.View):
    def __init__(self, channel_id):
        super().__init__(timeout=None)
        self.channel_id = channel_id

    @discord.ui.button(label="🚪 ノックする", style=discord.ButtonStyle.primary)
    async def knock(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "この部屋はもう存在しません。")

            owner = interaction.guild.get_member(room["owner_id"])
            channel = interaction.guild.get_channel(self.channel_id)

            if not owner or not channel:
                return await safe_reply(interaction, "部屋主または部屋が見つかりません。")

            if interaction.user.id == owner.id:
                return await safe_reply(interaction, "自分の部屋にはノック不要です。")

            if is_in_list(owner.id, "blacklist", interaction.user.id):
                return await safe_reply(interaction, "この部屋にはノックできません。")

            add_stat(interaction.guild.id, interaction.user.id, "knocks_sent")
            add_stat(interaction.guild.id, owner.id, "knocks_received")

            if is_in_list(owner.id, "favorites", interaction.user.id):
                await channel.set_permissions(interaction.user, view_channel=True, connect=True, speak=True)
                add_stat(interaction.guild.id, owner.id, "knocks_allowed")
                return await safe_reply(interaction, "❤️ お気に入り登録されているため、入室許可されました。")

            text_channel = interaction.guild.get_channel(room["knock_text_channel_id"])

            if not text_channel:
                return await safe_reply(interaction, "ノック用チャンネルが見つかりません。")

            msg = await text_channel.send(
                f"🚪 {owner.mention}\n"
                f"**{interaction.user.display_name}** さんが `{channel.name}` にノックしています。",
                view=KnockDecisionView(self.channel_id, interaction.user.id)
            )

            room["message_ids"].append(msg.id)

            await safe_reply(interaction, "部屋主にノックを送りました！")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "ノック処理でエラーが発生しました。")


