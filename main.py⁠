@bot.tree.command(name="usage_graph", description="日別のVC利用グラフを見る")
@app_commands.describe(days="表示する日数 1〜30")
async def usage_graph(interaction: discord.Interaction, days: int = 7):
    if interaction.guild is None:
        return await safe_reply(interaction, "サーバー内で使ってください。")

    days = max(1, min(30, days))
    now = int(time.time())
    start = now - days * 86400

    cur = db.execute(
        """
        SELECT created_at
        FROM room_logs
        WHERE guild_id=? AND created_at>=?
        """,
        (interaction.guild.id, start),
    )
    rows = cur.fetchall()

    buckets = []
    for i in range(days):
        day_start = now - (days - i) * 86400
        day_end = day_start + 86400
        label = time.strftime("%m/%d", time.localtime(day_start))
        count = sum(1 for (created_at,) in rows if day_start <= created_at < day_end)
        buckets.append((label, count))

    max_count = max([c for _, c in buckets] or [0])
    lines = [
        f"`{label}` {make_bar(count, max_count)} {count}回"
        for label, count in buckets
    ]

    embed = discord.Embed(
        title=f"📈 VC利用グラフ（直近{days}日）",
        description="\n".join(lines) if lines else "データがありません。",
        color=discord.Color.blurple(),
    )

    await interaction.response.send_message(embed=embed)


