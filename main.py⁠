def build_room_name(base_name: str, channel: discord.VoiceChannel):
    limit = channel.user_limit
    now_count = len(channel.members)
    limit_text = str(limit) if limit else "∞"

    clean = base_name
    if "【" in clean:
        clean = clean.split("【", 1)[0]

    return f"{clean}【{now_count}/{limit_text}】"[:100]


async def update_room_name(channel: discord.VoiceChannel):
    room = rooms.get(channel.id)
    if not room:
        return

    base_name = room.get("base_name") or channel.name.split("【", 1)[0]
    new_name = build_room_name(base_name, channel)

    if channel.name == new_name:
        return

    try:
        await channel.edit(name=new_name)
    except discord.HTTPException:
        pass
    except Exception:
        traceback.print_exc()




