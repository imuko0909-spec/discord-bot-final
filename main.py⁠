async def end_recruit(guild: discord.Guild, author_id: int, reason: str = "募集終了"):
    data = active_recruits.pop((guild.id, author_id), None)

    if not data:
        try:
            cur = db.execute(
                """
                SELECT id, channel_id, message_id
                FROM recruit_logs
                WHERE guild_id=? AND author_id=? AND is_active=1
                ORDER BY created_at DESC
                LIMIT 1
                """,
                (guild.id, author_id),
            )
            row = cur.fetchone()
            if row:
                data = {
                    "log_id": row[0],
                    "channel_id": row[1],
                    "message_id": row[2],
                }
        except sqlite3.Error:
            data = None

    if not data:
        return False

    finish_recruit_log(data.get("log_id"))

    channel = guild.get_channel(data.get("channel_id"))
    if isinstance(channel, discord.TextChannel):
        try:
            msg = await channel.fetch_message(data.get("message_id"))
            old_embed = msg.embeds[0] if msg.embeds else None

            embed = discord.Embed(
                title="🔴 募集終了",
                description="この募集は終了しました。",
                color=discord.Color.dark_grey(),
                timestamp=discord.utils.utcnow(),
            )

            if old_embed:
                for field in old_embed.fields:
                    embed.add_field(name=field.name, value=field.value, inline=field.inline)
                embed.set_footer(text=reason)

            await msg.edit(content=None, embed=embed, view=None)
        except discord.HTTPException:
            pass
        except Exception:
            traceback.print_exc()

    try:
        await update_status_panel(guild)
    except Exception:
        pass

    return True


