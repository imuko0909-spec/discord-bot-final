class ExtendButton(discord.ui.View):
    def __init__(self, channel: discord.VoiceChannel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="⏰ 10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.channel.id not in rooms:
            return await interaction.response.send_message("この部屋は存在しません。", ephemeral=True)

        owner_id = rooms[self.channel.id]["owner_id"]
        if interaction.user.id != owner_id:
            return await interaction.response.send_message("部屋主だけ延長できます。", ephemeral=True)

        rooms[self.channel.id]["time"] += 600
        await interaction.response.send_message(
            f"10分延長しました！残り {rooms[self.channel.id]['time'] // 60}分",
            ephemeral=True
        )

    @discord.ui.button(label="🗑 部屋削除", style=discord.ButtonStyle.danger)
    async def delete_room(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.channel.id not in rooms:
            return await interaction.response.send_message("この部屋は存在しません。", ephemeral=True)

        owner_id = rooms[self.channel.id]["owner_id"]
        if interaction.user.id != owner_id and interaction.user.id != MY_USER_ID:
            return await interaction.response.send_message("部屋主だけ削除できます。", ephemeral=True)

        await interaction.response.send_message("部屋を削除します。", ephemeral=True)
        try:
            await self.channel.delete()
        except discord.HTTPException:
            pass
        rooms.pop(self.channel.id, None)


class KnockDecisionView(discord.ui.View):
    def __init__(self, channel_id: int, requester_id: int):
        super().__init__(timeout=120)
        self.channel_id = channel_id
        self.requester_id = requester_id

    @discord.ui.button(label="✅ 許可", style=discord.ButtonStyle.success)
    async def allow(self, interaction: discord.Interaction, button: discord.ui.Button):
        room = rooms.get(self.channel_id)
        if not room:
            return await interaction.response.send_message("部屋が存在しません。", ephemeral=True)

        if interaction.user.id != room["owner_id"]:
            return await interaction.response.send_message("部屋主だけ操作できます。", ephemeral=True)

        channel = interaction.guild.get_channel(self.channel_id)
        member = interaction.guild.get_member(self.requester_id)

        if not channel or not member:
            return await interaction.response.send_message("対象が見つかりません。", ephemeral=True)

        await channel.set_permissions(member, view_channel=True, connect=True, speak=True)

        try:
            if member.voice and member.voice.channel:
                await member.move_to(channel)
        except discord.HTTPException:
            pass

        await interaction.response.send_message(f"{member.display_name} さんを許可しました。", ephemeral=True)

    @discord.ui.button(label="❌ 拒否", style=discord.ButtonStyle.danger)
    async def deny(self, interaction: discord.Interaction, button: discord.ui.Button):
        room = rooms.get(self.channel_id)
        if not room:
            return await interaction.response.send_message("部屋が存在しません。", ephemeral=True)

        if interaction.user.id != room["owner_id"]:
            return await interaction.response.send_message("部屋主だけ操作できます。", ephemeral=True)

        member = interaction.guild.get_member(self.requester_id)
        await interaction.response.send_message(
            f"{member.display_name if member else '相手'} さんを拒否しました。",
            ephemeral=True
        )


class KnockButtonView(discord.ui.View):
    def __init__(self, channel: discord.VoiceChannel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="🚪 ノックする", style=discord.ButtonStyle.primary)
    async def knock(self, interaction: discord.Interaction, button: discord.ui.Button):
        room = rooms.get(self.channel.id)
        if not room:
            return await interaction.response.send_message("この部屋は存在しません。", ephemeral=True)

        owner = interaction.guild.get_member(room["owner_id"])
        if not owner:
            return await interaction.response.send_message("部屋主が見つかりません。", ephemeral=True)

        if interaction.user.id == owner.id:
            return await interaction.response.send_message("自分の部屋にはノック不要です。", ephemeral=True)

        if is_in_list(owner.id, "blacklist", interaction.user.id):
            return await interaction.response.send_message("この部屋にはノックできません。", ephemeral=True)

        try:
            await owner.send(
                f"🚪 {interaction.user.display_name} さんがあなたのノック部屋に入りたがっています。\n"
                f"サーバー: {interaction.guild.name}\n"
                f"部屋: {self.channel.name}",
                view=KnockDecisionView(self.channel.id, interaction.user.id)
            )
            await interaction.response.send_message("部屋主にノックを送りました！", ephemeral=True)
        except discord.Forbidden:
            await interaction.response.send_message("部屋主にDMが送れませんでした。", ephemeral=True)


async def manage_room_timer(channel: discord.VoiceChannel):
    while channel.id in rooms:
        await asyncio.sleep(60)

        if channel.id not in rooms:
            return

        rooms[channel.id]["time"] -= 60

        if rooms[channel.id]["time"] <= 0:
            try:
                await channel.delete()
            except discord.HTTPException:
                pass
            rooms.pop(channel.id, None)
            return


async def create_free_room(guild, member, category):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=True),
        member: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
            mute_members=True,
            deafen_members=True
        )
    }

    channel = await guild.create_voice_channel(
        name=f"🔓{member.display_name}の貸切部屋",
        category=category,
        overwrites=overwrites
    )

    rooms[channel.id] = {
        "owner_id": member.id,
        "time": 600,
        "type": "free"
    }

    await channel.send(
        "🔓 貸切部屋を作成しました。\n10分後に自動削除されます。",
        view=ExtendButton(channel)
    )

    bot.loop.create_task(manage_room_timer(channel))
    return channel


async def create_knock_room(guild, member, category):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=False),
        member: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
            mute_members=True,
            deafen_members=True
        )
    }

    channel = await guild.create_voice_channel(
        name=f"🔐{member.display_name}のノック部屋",
        category=category,
        overwrites=overwrites
    )

    rooms[channel.id] = {
        "owner_id": member.id,
        "time": 600,
        "type": "knock"
    }

    await channel.send(
        "🔐 ノック部屋を作成しました。\n入りたい人は下のボタンからノックしてください。",
        view=KnockButtonView(channel)
    )

    await channel.send(
        "部屋主専用パネルです。",
        view=ExtendButton(channel)
    )

    bot.loop.create_task(manage_room_timer(channel))
    return channel


