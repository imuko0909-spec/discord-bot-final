    if is_in_list(interaction.user.id, "blacklist", member.id):
        return await safe_reply(interaction, "ブラックリストのメンバーは招待できません。")

    await channel.set_permissions(member, view_channel=True, connect=True, speak=True)

    try:
        await member.send(
            f"🎫 **{interaction.guild.name}** の **{channel.name}** に招待されました。"
        )
    except discord.HTTPException:
        pass

    await safe_reply(interaction, f"{member.display_name} さんを招待しました。")


