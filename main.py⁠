@bot.event
async def on_voice_state_update(member: discord.Member, before, after):
    if member.bot:
        return

    try:
        if after.channel:
            record_activity(after.channel.guild.id, member.id, "voice_join")
        elif before.channel:
            record_activity(before.channel.guild.id, member.id, "voice_leave")
    except Exception:
        traceback.print_exc()

    if after.channel and after.channel.id in rooms:
        cancel_empty_delete(after.channel.id)
        await log_voice_move(member, after.channel, "入室")
        await update_room_name(after.channel)
        await update_status_panel(after.channel.guild)

    reception_id = get_config_channel_id(after.channel.guild.id, "reception_channel_id", RECEPTION_CHANNEL_ID) if after.channel else RECEPTION_CHANNEL_ID

    if reception_id and after.channel and after.channel.id == reception_id:
        try:
            channel = await create_free_room(after.channel.guild, member, after.channel.category)
            await member.move_to(channel)
        except Exception:
            traceback.print_exc()


    try:
        if before.channel:
            data = active_recruits.get((before.channel.guild.id, member.id))
            if data and data.get("vc_channel_id") == before.channel.id:
                if not after.channel or after.channel.id != before.channel.id:
                    await end_recruit(before.channel.guild, member.id, reason="募集主がVCから退出したため自動終了")
    except Exception:
        traceback.print_exc()

    if before.channel and before.channel.id in rooms:
        await log_voice_move(member, before.channel, "退出")
        await transfer_room_owner_if_needed(before.channel)
        await update_room_name(before.channel)
        await update_status_panel(before.channel.guild)
        if len(before.channel.members) == 0:
            schedule_empty_delete(before.channel.id, before.channel.guild)



