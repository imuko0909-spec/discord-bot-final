class ExtendButton(discord.ui.View):
    def __init__(self, channel: discord.VoiceChannel):
        super().__init__(timeout=None)
        self.channel = channel

    @discord.ui.button(label="10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction: discord.Interaction, button: discord.ui.Button):
        if self.channel.id not in rooms:
            return await interaction.response.send_message("この部屋は存在しません。", ephemeral=True)

        rooms[self.channel.id] += 600
        await interaction.response.send_message(
            f"10分延長しました！残り {rooms[self.channel.id] // 60}分",
            ephemeral=True
        )


async def manage_room_timer(channel: discord.VoiceChannel):
    while rooms.get(channel.id, 0) > 0:
        await asyncio.sleep(60)

        if channel.id not in rooms:
            return

        rooms[channel.id] -= 60

        if rooms[channel.id] <= 0:
            try:
                await channel.delete()
            except discord.HTTPException:
                pass
            rooms.pop(channel.id, None)
            return


async def create_private_room(
    guild: discord.Guild,
    member: discord.Member,
    category: discord.CategoryChannel | None = None,
    name_prefix: str = ""
):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=True),
        member: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
            mute_members=True,
            deafen_members=True,
        ),
    }

    channel = await guild.create_voice_channel(
        name=f"{name_prefix}{member.display_name}の個室",
        category=category,
        overwrites=overwrites,
    )

    rooms[channel.id] = 600

    try:
        await channel.send(
            "個室へようこそ！10分後に自動削除されます。",
            view=ExtendButton(channel)
        )
    except discord.HTTPException:
        pass

    bot.loop.create_task(manage_room_timer(channel))
    return channel


