class MyListBot(commands.Bot):
    def __init__(self):
        super().__init__(command_prefix="!", intents=intents)
        self._synced = False

    async def setup_hook(self):
        self.add_view(CreateVCView())

    async def on_ready(self):
        if not self._synced:
            if self.guilds:
                # 各サーバーへ即時同期（反映が速く、コマンド状態をリフレッシュ）
                for guild in self.guilds:
                    self.tree.copy_global_to(guild=guild)
                # 旧グローバルコマンドを消して重複を防ぐ
                self.tree.clear_commands(guild=None)
                await self.tree.sync()
                for guild in self.guilds:
                    synced = await self.tree.sync(guild=guild)
                    print(f"「{guild.name}」に {len(synced)} 件のコマンドを同期しました。")
            else:
                synced = await self.tree.sync()
                print(f"グローバルに {len(synced)} 件のコマンドを同期しました（参加サーバーなし）。")
            self._synced = True
        print(f"✅ {self.user} でログイン完了。（参加サーバー数: {len(self.guilds)}）")


