@bot.tree.command(name="mylist_view", description="自分のお気に入り・ブラックリストを見る")
async def mylist_view(interaction: discord.Interaction):
    if interaction.guild is None:
        return await interaction.response.send_message("サーバー内で使用してください。", ephemeral=True)

    try:
        fav_ids = get_list(interaction.user.id, "favorites")
        bl_ids = get_list(interaction.user.id, "blacklist")
    except sqlite3.Error:
        return await interaction.response.send_message(DB_ERROR_MSG, ephemeral=True)

    def names(ids):
        if not ids:
            return "（なし）"
        return "\n".join(
            f"・{interaction.guild.get_member(i).display_name if interaction.guild.get_member(i) else f'退出済みユーザー ID:{i}'}"
            for i in ids
        )[:1024]

    embed = discord.Embed(title="📋 あなたのマイリスト", color=discord.Color.blurple())
    embed.add_field(name=f"❤️ お気に入り（{len(fav_ids)}人）", value=names(fav_ids), inline=False)
    embed.add_field(name=f"🚫 ブラックリスト（{len(bl_ids)}人）", value=names(bl_ids), inline=False)

    await interaction.response.send_message(embed=embed, ephemeral=True)


