async def legacy_economy_voice_reward_listener(member: discord.Member, before, after):
    if member.bot:
        return
    try:
        now = int(time.time())
        if after.channel and not before.channel:
            db.execute(
                """
                INSERT OR REPLACE INTO vc_economy_sessions
                (guild_id, user_id, joined_at)
                VALUES (?, ?, ?)
                """,
                (after.channel.guild.id, member.id, now),
            )
            db.commit()
        if before.channel and not after.channel:
            cur = db.execute(
                "SELECT joined_at FROM vc_economy_sessions WHERE guild_id=? AND user_id=?",
                (before.channel.guild.id, member.id),
            )
            row = cur.fetchone()
            if row:
                humans = [m for m in before.channel.members if not m.bot]
                if member not in humans:
                    humans.append(member)
                min_people = get_vc_reward_min_people(before.channel.guild.id) if "get_vc_reward_min_people" in globals() else 1
                joined_at = int(row[0])
                minutes = max(0, (now - joined_at) // 60)
                units = minutes // 10
                reward = units * get_vc_reward_per_10min(before.channel.guild.id)
                if reward > 0 and len(humans) >= min_people:
                    if "add_points_with_history" in globals():
                        add_points_with_history(before.channel.guild.id, member.id, reward, "vc_reward")
                    else:
                        add_points(before.channel.guild.id, member.id, reward)
                db.execute(
                    "DELETE FROM vc_economy_sessions WHERE guild_id=? AND user_id=?",
                    (before.channel.guild.id, member.id),
                )
                db.commit()
    except Exception:
        traceback.print_exc()






