class KnockDecisionView(discord.ui.View):
    def __init__(self, channel_id, requester_id):
        super().__init__(timeout=180)
        self.channel_id = channel_id
        self.requester_id = requester_id

    @discord.ui.button(label="✅ 許可", style=discord.ButtonStyle.success)
    async def allow(self, interaction, button):
        room = rooms.get(self.channel_id)
        if not room:
            return await interaction.response.send_message("部屋がありません。", ephemeral=True)

        if interaction.user.id != room["owner_id"]:
            return await interaction.response.send_message("部屋主だけ操作できます。", ephemeral=True)

        channel = interaction.guild.get_channel(self.channel_id)
        member = interaction.guild.get_member(self.requester_id)

        if not channel or not member:
            return await interaction.response.send_message("対象が見つかりません。", ephemeral=True)

        await channel.set_permissions(member, view_channel=True, connect=True, speak=True)

        try:
            if member.voice and member.voice.channel:
                await member.move_to(channel)
        except:
            pass

        await interaction.response.send_message(
            f"✅ {member.display_name} さんを許可しました。",
            ephemeral=True
        )

    @discord.ui.button(label="❌ 拒否", style=discord.ButtonStyle.danger)
    async def deny(self, interaction, button):
        room = rooms.get(self.channel_id)
        if not room:
            return await interaction.response.send_message("部屋がありません。", ephemeral=True)

        if interaction.user.id != room["owner_id"]:
            return await interaction.response.send_message("部屋主だけ操作できます。", ephemeral=True)

        member = interaction.guild.get_member(self.requester_id)

        await interaction.response.send_message(
            f"❌ {member.display_name if member else '相手'} さんを拒否しました。",
            ephemeral=True
        )


class KnockButtonView(discord.ui.View):
    def __init__(self, channel_id):
        super().__init__(timeout=None)
        self.channel_id = channel_id

    @discord.ui.button(label="🚪 ノックする", style=discord.ButtonStyle.primary)
    async def knock(self, interaction, button):
        room = rooms.get(self.channel_id)
        if not room:
            return await interaction.response.send_message("この部屋はもう存在しません。", ephemeral=True)

        owner = interaction.guild.get_member(room["owner_id"])
        channel = interaction.guild.get_channel(self.channel_id)

        if not owner or not channel:
            return await interaction.response.send_message("部屋主または部屋が見つかりません。", ephemeral=True)

        if interaction.user.id == owner.id:
            return await interaction.response.send_message("自分の部屋にはノック不要です。", ephemeral=True)

        if is_in_list(owner.id, "blacklist", interaction.user.id):
            return await interaction.response.send_message("この部屋にはノックできません。", ephemeral=True)

        if is_in_list(owner.id, "favorites", interaction.user.id):
            await channel.set_permissions(interaction.user, view_channel=True, connect=True, speak=True)
            return await interaction.response.send_message(
                "❤️ お気に入り登録されているため、入室許可されました。",
                ephemeral=True
            )

        try:
            await owner.send(
                f"🚪 **{interaction.user.display_name}** さんがノックしています。\n"
                f"サーバー: {interaction.guild.name}\n"
                f"部屋: {channel.name}",
                view=KnockDecisionView(self.channel_id, interaction.user.id)
            )
            await interaction.response.send_message("部屋主にノックを送りました！", ephemeral=True)
        except discord.Forbidden:
            await interaction.response.send_message(
                "部屋主にDMが送れませんでした。部屋主のDM設定を確認してください。",
                ephemeral=True
            )


