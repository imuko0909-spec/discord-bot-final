    @discord.ui.button(label="🔓 鍵を開ける", style=discord.ButtonStyle.success)
    async def unlock(self, interaction, button):
        if not await self.owner_check(interaction):
            return
        channel = interaction.guild.get_channel(self.channel_id)
        await channel.set_permissions(interaction.guild.default_role, view_channel=True, connect=True)
