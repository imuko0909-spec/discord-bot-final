def get_vc_reward_min_people(guild_id: int):
    try:
        return int(get_config(guild_id, "vc_reward_min_people", "1"))
    except Exception:
        return 1


async def vc_point_reward_loop(guild_id: int, user_id: int):
    await bot.wait_until_ready()
    key = (guild_id, user_id)

    try:
        while not bot.is_closed():
            guild = bot.get_guild(guild_id)
            member = guild.get_member(user_id) if guild else None

            if not member or not member.voice or not member.voice.channel:
                break

            channel = member.voice.channel
            humans = [m for m in channel.members if not m.bot]
            minimum = get_vc_reward_min_people(guild_id)

            now = int(time.time())
            cur = db.execute(
                """
                SELECT last_reward_at
                FROM vc_point_live_sessions
                WHERE guild_id=? AND user_id=?
                """,
                (guild_id, user_id),
            )
            row = cur.fetchone()

            if not row:
                db.execute(
                    """
                    INSERT OR REPLACE INTO vc_point_live_sessions
                    (guild_id, user_id, channel_id, last_reward_at)
                    VALUES (?, ?, ?, ?)
                    """,
                    (guild_id, user_id, channel.id, now),
                )
                db.commit()
                last_reward = now
            else:
                last_reward = int(row[0])

            if now - last_reward >= 600:
                reward = get_vc_reward_per_10min(guild_id)

                if reward > 0 and len(humans) >= minimum:
                    add_points(guild_id, user_id, reward)

                db.execute(
                    """
                    UPDATE vc_point_live_sessions
                    SET channel_id=?, last_reward_at=?
                    WHERE guild_id=? AND user_id=?
                    """,
                    (channel.id, now, guild_id, user_id),
                )
                db.commit()

            await asyncio.sleep(30)

    except asyncio.CancelledError:
        pass
    except Exception:
        traceback.print_exc()
    finally:
        db.execute(
            """
            DELETE FROM vc_point_live_sessions
            WHERE guild_id=? AND user_id=?
            """,
            (guild_id, user_id),
        )
        db.commit()
        vc_point_tasks.pop(key, None)


def start_vc_point_task(member: discord.Member):
    if member.bot or not member.voice or not member.voice.channel:
        return

    key = (member.guild.id, member.id)
    task = vc_point_tasks.get(key)

    if task and not task.done():
        return

    vc_point_tasks[key] = bot.loop.create_task(
        vc_point_reward_loop(member.guild.id, member.id)
    )


def stop_vc_point_task(member: discord.Member):
    key = (member.guild.id, member.id)
    task = vc_point_tasks.get(key)

    if task and not task.done():
        task.cancel()


@bot.listen("on_voice_state_update")
async def vc_point_state_listener(member: discord.Member, before, after):
    if member.bot:
        return

    if after.channel:
        start_vc_point_task(member)

    if before.channel and not after.channel:
        stop_vc_point_task(member)


