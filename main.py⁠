class KnockDecisionView(discord.ui.View):
    def __init__(self, channel_id, requester_id):
        super().__init__(timeout=180)
        self.channel_id = channel_id
        self.requester_id = requester_id

    @discord.ui.button(label="✅ 許可", style=discord.ButtonStyle.success)
    async def allow(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            channel = interaction.guild.get_channel(self.channel_id)
            member = interaction.guild.get_member(self.requester_id)

            if not channel or not member:
                return await safe_reply(interaction, "対象が見つかりません。")

            await channel.set_permissions(member, view_channel=True, connect=True, speak=True)

            try:
                if member.voice and member.voice.channel:
                    await member.move_to(channel)
            except discord.HTTPException:
                pass

            await safe_reply(interaction, f"✅ {member.display_name} さんを許可しました。")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "許可処理でエラーが発生しました。")

    @discord.ui.button(label="❌ 拒否", style=discord.ButtonStyle.danger)
    async def deny(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "部屋がありません。")

            if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
                return await safe_reply(interaction, "部屋主だけ操作できます。")

            member = interaction.guild.get_member(self.requester_id)
            await safe_reply(interaction, f"❌ {member.display_name if member else '相手'} さんを拒否しました。")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "拒否処理でエラーが発生しました。")


class KnockButtonView(discord.ui.View):
    def __init__(self, channel_id):
        super().__init__(timeout=None)
        self.channel_id = channel_id

    @discord.ui.button(label="🚪 ノックする", style=discord.ButtonStyle.primary)
    async def knock(self, interaction, button):
        try:
            room = rooms.get(self.channel_id)
            if not room:
                return await safe_reply(interaction, "この部屋はもう存在しません。")

            owner = interaction.guild.get_member(room["owner_id"])
            channel = interaction.guild.get_channel(self.channel_id)

            if not owner or not channel:
                return await safe_reply(interaction, "部屋主または部屋が見つかりません。")

            if interaction.user.id == owner.id:
                return await safe_reply(interaction, "自分の部屋にはノック不要です。")

            if is_in_list(owner.id, "blacklist", interaction.user.id):
                return await safe_reply(interaction, "この部屋にはノックできません。")

            if is_in_list(owner.id, "favorites", interaction.user.id):
                await channel.set_permissions(interaction.user, view_channel=True, connect=True, speak=True)
                return await safe_reply(interaction, "❤️ お気に入り登録されているため、入室許可されました。")

            text_channel = interaction.guild.get_channel(room["knock_text_channel_id"])

            if not text_channel:
                return await safe_reply(interaction, "ノック用チャンネルが見つかりません。")

            msg = await text_channel.send(
                f"🚪 {owner.mention}\n"
                f"**{interaction.user.display_name}** さんが `{channel.name}` にノックしています。",
                view=KnockDecisionView(self.channel_id, interaction.user.id)
            )

            room["message_ids"].append(msg.id)

            await safe_reply(interaction, "部屋主にノックを送りました！")

        except Exception:
            traceback.print_exc()
            await safe_reply(interaction, "ノック処理でエラーが発生しました。")


class RenameRoomModal(discord.ui.Modal, title="部屋名変更"):
    new_name = discord.ui.TextInput(label="新しい部屋名", max_length=80)

    def __init__(self, channel_id):
        super().__init__()
        self.channel_id = channel_id

    async def on_submit(self, interaction):
        if not is_room_owner(interaction.user.id, self.channel_id) and interaction.user.id != MY_USER_ID:
            return await safe_reply(interaction, "部屋主だけ変更できます。")

        channel = interaction.guild.get_channel(self.channel_id)
        if not channel:
            return await safe_reply(interaction, "部屋が見つかりません。")

        await channel.edit(name=str(self.new_name))
        await safe_reply(interaction, "部屋名を変更しました。")


class LimitRoomModal(discord.ui.Modal, title="人数制限変更"):
    limit = discord.ui.TextInput(label="人数 0〜99", max_length=2)

    def __init__(self, channel_id):
        super().__init__()
        self.channel_id = channel_id

    async def on_submit(self, interaction):
        if not is_room_owner(interaction.user.id, self.channel_id) and interaction.user.id != MY_USER_ID:
            return await safe_reply(interaction, "部屋主だけ変更できます。")

        try:
            value = int(str(self.limit))
            if value < 0 or value > 99:
                raise ValueError
        except Exception:
            return await safe_reply(interaction, "0〜99の数字で入力してください。")

        channel = interaction.guild.get_channel(self.channel_id)
        if not channel:
            return await safe_reply(interaction, "部屋が見つかりません。")

        await channel.edit(user_limit=value)
        await safe_reply(interaction, f"人数制限を {value} に変更しました。")


class RoomManageView(discord.ui.View):
    def __init__(self, channel_id):
        super().__init__(timeout=None)
        self.channel_id = channel_id

    async def owner_check(self, interaction):
        room = rooms.get(self.channel_id)
        if not room:
            await safe_reply(interaction, "部屋が存在しません。")
            return False

        if interaction.user.id != room["owner_id"] and interaction.user.id != MY_USER_ID:
            await safe_reply(interaction, "部屋主だけ操作できます。")
            return False

        return True

    @discord.ui.button(label="✏️ 名前変更", style=discord.ButtonStyle.primary)
    async def rename(self, interaction, button):
        if await self.owner_check(interaction):
            await interaction.response.send_modal(RenameRoomModal(self.channel_id))

    @discord.ui.button(label="👥 人数変更", style=discord.ButtonStyle.primary)
    async def limit(self, interaction, button):
        if await self.owner_check(interaction):
            await interaction.response.send_modal(LimitRoomModal(self.channel_id))

    @discord.ui.button(label="🔒 鍵をかける", style=discord.ButtonStyle.secondary)
    async def lock(self, interaction, button):
        if not await self.owner_check(interaction):
            return
        channel = interaction.guild.get_channel(self.channel_id)
        await channel.set_permissions(interaction.guild.default_role, view_channel=True, connect=False)
        await safe_reply(interaction, "鍵をかけました。")

    @discord.ui.button(label="🔓 鍵を開ける", style=discord.ButtonStyle.success)
    async def unlock(self, interaction, button):
        if not await self.owner_check(interaction):
            return
        channel = interaction.guild.get_channel(self.channel_id)
        await channel.set_permissions(interaction.guild.default_role, view_channel=True, connect=True)
        await safe_reply(interaction, "鍵を開けました。")

    @discord.ui.button(label="⏰ 10分延長", style=discord.ButtonStyle.primary)
    async def extend(self, interaction, button):
        if not await self.owner_check(interaction):
            return
        rooms[self.channel_id]["time"] += 600
        await safe_reply(interaction, f"10分延長しました。残り {rooms[self.channel_id]['time'] // 60}分")

    @discord.ui.button(label="🗑 部屋削除", style=discord.ButtonStyle.danger)
    async def delete(self, interaction, button):
        if not await self.owner_check(interaction):
            return
        await safe_reply(interaction, "部屋を削除します。")
        await delete_room(self.channel_id, interaction.guild)


async def room_timer(channel_id, guild):
    while channel_id in rooms:
        await asyncio.sleep(60)

        if channel_id not in rooms:
            return

        rooms[channel_id]["time"] -= 60

        if rooms[channel_id]["time"] <= 0:
            await delete_room(channel_id, guild)
            return


async def create_free_room(guild, member, category):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=True),
        member: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
            mute_members=True,
            deafen_members=True
        )
    }

    channel = await guild.create_voice_channel(
        name=f"🔓{member.display_name}の貸切部屋",
        category=category,
        overwrites=overwrites
    )

    rooms[channel.id] = {
        "owner_id": member.id,
        "time": ROOM_TIME,
        "type": "free",
        "knock_text_channel_id": None,
        "message_ids": []
    }

    text_channel = await get_or_create_knock_text_channel(guild)

    embed = discord.Embed(
        title="🔓 貸切部屋を作成しました",
        description=f"部屋主: {member.mention}\n部屋: {channel.mention}",
        color=discord.Color.green()
    )

    msg = await text_channel.send(embed=embed, view=RoomManageView(channel.id))

    rooms[channel.id]["knock_text_channel_id"] = text_channel.id
    rooms[channel.id]["message_ids"] = [msg.id]

    bot.loop.create_task(room_timer(channel.id, guild))
    return channel


async def create_knock_room(guild, member, category):
    overwrites = {
        guild.default_role: discord.PermissionOverwrite(view_channel=True, connect=False),
        member: discord.PermissionOverwrite(
            view_channel=True,
            connect=True,
            speak=True,
            manage_channels=True,
            move_members=True,
            mute_members=True,
            deafen_members=True
        )
    }

    channel = await guild.create_voice_channel(
        name=f"🔐{member.display_name}のノック部屋",
        category=category,
        overwrites=overwrites
    )

    rooms[channel.id] = {
        "owner_id": member.id,
        "time": ROOM_TIME,
        "type": "knock",
        "knock_text_channel_id": None,
        "message_ids": []
    }

    text_channel = await get_or_create_knock_text_channel(guild)

    embed = discord.Embed(
        title="🔐 ノック部屋",
        description=(
            f"部屋主: {member.mention}\n"
            f"部屋: {channel.mention}\n\n"
            f"入りたい人は下の **🚪ノックする** を押してください。"
        ),
        color=discord.Color.purple()
    )

    knock_msg = await text_channel.send(embed=embed, view=KnockButtonView(channel.id))
    manage_msg = await text_channel.send(
        f"🎛 {member.mention} さんの部屋管理パネル",
        view=RoomManageView(channel.id)
    )

    rooms[channel.id]["knock_text_channel_id"] = text_channel.id
    rooms[channel.id]["message_ids"] = [knock_msg.id, manage_msg.id]

    bot.loop.create_task(room_timer(channel.id, guild))
    return channel


