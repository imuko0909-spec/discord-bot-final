class ChatRecruitTargetView(discord.ui.View):
    def __init__(self, author_id: int, recruit_type: str):
        super().__init__(timeout=60)
        self.author_id = author_id
        self.recruit_type = recruit_type

    async def send_recruit(self, interaction: discord.Interaction, target: str):
        key = (interaction.guild.id, interaction.user.id)
        if key in active_recruits:
            return await safe_reply(interaction, "すでに募集中です。先に `/募集終了` で終了してください。")

        configured_id = get_config_channel_id(interaction.guild.id, "recruit_channel_id", 0)
        channel = interaction.guild.get_channel(configured_id) if configured_id else None

        if not isinstance(channel, discord.TextChannel):
            channel = discord.utils.get(interaction.guild.text_channels, name=RECRUIT_CHANNEL_NAME)

        if not channel:
