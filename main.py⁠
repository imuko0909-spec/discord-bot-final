import discord
from discord import app_commands
from discord.ext import commands
import asyncio
import os

MY_USER_ID = 1232865763094827112

RECEPTION_CHANNEL_ID = 1521453980268498974

intents = discord.Intents.default()
intents.members = True
intents.voice_states = True

user_lists = {"favorites": [], "blacklist": []}

rooms = {}


class MyListBot(commands.Bot):
    def __init__(self):
        super().__init__(command_prefix="!", intents=intents)

    async def setup_hook(self):
        self.add_view(CreateVCView())
        synced = await self.tree.sync()
        print(f"{len(synced)} 件のコマンドを同期しました。")

    async def on_ready(self):
        print(f"✅ {self.user} でログイン完了。")


bot = MyListBot()


class ActionView(discord.ui.View):
    def __init__(self, target_member: discord.Member):
        super().__init__(timeout=60)
        self.target = target_member

    @discord.ui.button(label="❤️ お気に入り追加", style=discord.ButtonStyle.green)
    async def add_fav(self, interaction: discord.Interaction, button: discord.ui.Button):
        uid = self.target.id
        if uid not in user_lists["favorites"]:
            user_lists["favorites"].append(uid)
            await interaction.response.send_message(
                f"{self.target.display_name} をお気に入りに入れました。", ephemeral=True
            )
        else:
            await interaction.response.send_message(
                f"{self.target.display_name} はすでにお気に入りに登録済みです。", ephemeral=True
            )

    @discord.ui.button(label="💔 お気に入り解除", style=discord.ButtonStyle.secondary)
    async def remove_fav(self, interaction: discord.Interaction, button: discord.ui.Button):
        uid = self.target.id
        if uid in user_lists["favorites"]:
            user_lists["favorites"].remove(uid)
            await interaction.response.send_message(
                f"{self.target.display_name} をお気に入りから解除しました。", ephemeral=True
            )
        else:
            await interaction.response.send_message(
                f"{self.target.display_name} はお気に入りに登録されていません。", ephemeral=True
            )

    @discord.ui.button(label="🚫 BL追加", style=discord.ButtonStyle.danger)
    async def add_bl(self, interaction: discord.Interaction, button: discord.ui.Button):
        uid = self.target.id
        if uid not in user_lists["blacklist"]:
            user_lists["blacklist"].append(uid)
            await interaction.response.send_message(
                f"{self.target.display_name} をブラックリストに入れました。", ephemeral=True
            )
        else:
            await interaction.response.send_message(
                f"{self.target.display_name} はすでにブラックリストに登録済みです。", ephemeral=True
            )


class SelectMemberView(discord.ui.View):
    def __init__(self, guild: discord.Guild):
        super().__init__(timeout=60)
        options = [
            discord.SelectOption(label=m.display_name[:100], value=str(m.id))
            for m in guild.members if not m.bot and m.id != MY_USER_ID
        ][:25]
        self.add_item(self.MemberSelect(options))

    class MemberSelect(discord.ui.Select):
        def __init__(self, options):
            if not options:
                options = [discord.SelectOption(label="（対象メンバーがいません）", value="none")]
            super().__init__(placeholder="メンバーを選択してください...", options=options)

        async def callback(self, interaction: discord.Interaction):
            if self.values[0] == "none":
                await interaction.response.send_message(
                    "操作できるメンバーがいません。", ephemeral=True
                )
                return
            target_id = int(self.values[0])
            target_member = interaction.guild.get_member(target_id)
            await interaction.response.send_message(
                f"{target_member.display_name} を選択しました。操作を選んでください。",
                view=ActionView(target_member),
                ephemeral=True
            )


@bot.tree.command(name="mylist", description="マイリスト管理メニューを開く")
async def mylist(interaction: discord.Interaction):
    if interaction.user.id != MY_USER_ID:
        return await interaction.response.send_message("権限がありません。", ephemeral=True)
    if interaction.guild is None:
