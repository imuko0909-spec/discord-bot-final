def get_activity_lists(guild: discord.Guild, active_days: int = 7, limit: int = 15):
    now = int(time.time())
    border = now - active_days * 86400

    cur = db.execute(
        """
        SELECT user_id, last_seen, action
        FROM user_activity
        WHERE guild_id=?
        ORDER BY last_seen DESC
        """,
        (guild.id,),
    )
    rows = cur.fetchall()
    activity_map = {user_id: (last_seen, action) for user_id, last_seen, action in rows}

    active_lines = []
    inactive_lines = []
    no_record_lines = []

    members = [m for m in guild.members if not m.bot]

    for member in members:
        data = activity_map.get(member.id)

        if data:
            last_seen, _action = data
            line = f"・{member.display_name}：{format_last_seen(last_seen)}"

            if last_seen >= border:
                active_lines.append((last_seen, line))
            else:
                inactive_lines.append((last_seen, line))
        else:
            no_record_lines.append(f"・{member.display_name}")

    active_lines.sort(reverse=True, key=lambda x: x[0])
    inactive_lines.sort(key=lambda x: x[0])

    def pack(lines: list[str], total_count: int):
        if not lines:
            return "（なし）"

        text = "\n".join(lines[:limit])

        if total_count > limit:
            text += f"\n…他 {total_count - limit}人"

        return text[:1024]

    active_text = pack([line for _, line in active_lines], len(active_lines))
    inactive_text = pack([line for _, line in inactive_lines], len(inactive_lines))
    no_record_text = pack(no_record_lines, len(no_record_lines))

    return active_text, inactive_text, no_record_text


